<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.currencyexchange.controller.MainController"
            stylesheets="@styles.css"
            styleClass="app-root">

    <left>
        <VBox fx:id="sidebar" prefWidth="248" styleClass="sidebar">
            <HBox styleClass="sidebar-brand" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets right="22" left="22"/></padding>
                <Label text="💱" styleClass="brand-icon"/>
                <VBox spacing="1" alignment="CENTER_LEFT" styleClass="brand-copy">
                    <Label text="FX Exchange" styleClass="brand"/>
                    <Label text="Сеть обменных касс" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>

            <ScrollPane fx:id="sidebarScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <content>
            <VBox styleClass="sidebar-menu" spacing="8" fillWidth="true">
                <padding><Insets top="18" right="14" bottom="18" left="14"/></padding>

                <Label text="ОСНОВНОЕ" styleClass="sidebar-section"/>
                <Button fx:id="dashboardButton" text="◫  Dashboard" onAction="#showDashboard" maxWidth="Infinity" styleClass="sidebar-button"/>
                <Button fx:id="currenciesButton" text="¤  Валюты" onAction="#showCurrencies" maxWidth="Infinity" styleClass="sidebar-button"/>
                <Button fx:id="exchangeRatesButton" text="↕  Курсы валют" onAction="#showExchangeRates" maxWidth="Infinity" styleClass="sidebar-button"/>
                <Button fx:id="cashDesksButton" text="▣  Кассы" onAction="#showCashDesks" maxWidth="Infinity" styleClass="sidebar-button"/>

                <Label text="ОПЕРАЦИИ" styleClass="sidebar-section"/>
                <Button fx:id="exchangeOperationsButton" text="⇄  Операции обмена" onAction="#showExchangeOperations" wrapText="true" maxWidth="Infinity" styleClass="sidebar-button"/>
                <Button fx:id="incassationsButton" text="⇅  Инкассации" onAction="#showIncassations" maxWidth="Infinity" styleClass="sidebar-button"/>
                <Button fx:id="reportsButton" text="▤  Отчеты" onAction="#showReports" maxWidth="Infinity" styleClass="sidebar-button"/>
            </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="main-shell">
            <center>
                <StackPane fx:id="contentArea" styleClass="content-area"/>
            </center>
        </BorderPane>
    </center>
</BorderPane>
