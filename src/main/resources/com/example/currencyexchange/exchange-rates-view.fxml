<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.controlsfx.control.SearchableComboBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.ExchangeRateController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Курсы валют" styleClass="page-title"/>
            <Label text="Табличный экран с акцентом на чистую типографику и быстрые действия" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox styleClass="section-card" spacing="0" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="Добавить" onAction="#addRate" styleClass="primary-button">
                <graphic><FontIcon iconLiteral="fas-plus" iconSize="12" styleClass="app-icon"/></graphic>
            </Button>
            <Button text="Изменить" onAction="#updateRate" styleClass="secondary-button">
                <graphic><FontIcon iconLiteral="fas-pen" iconSize="12" styleClass="app-icon"/></graphic>
            </Button>
            <Button text="Удалить" onAction="#deleteRate" styleClass="danger-button">
                <graphic><FontIcon iconLiteral="fas-trash" iconSize="12" styleClass="app-icon"/></graphic>
            </Button>
            <Button text="BNM" onAction="#importBnmRates" styleClass="secondary-button">
                <graphic><FontIcon iconLiteral="fas-cloud-download-alt" iconSize="12" styleClass="app-icon"/></graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="4">
                <Label text="Валюта" styleClass="filter-label"/>
                <SearchableComboBox fx:id="filterCurrencyBox" prefWidth="220" promptText="Все"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Дата" styleClass="filter-label"/>
                <DatePicker fx:id="filterDatePicker" prefWidth="170" styleClass="flat-date-picker"/>
            </VBox>
        </HBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="content-scroll">
            <content>
                <VBox spacing="0" styleClass="rate-groups-scroll-content">
                    <VBox fx:id="rateDateGroupsContainer" spacing="12" styleClass="rate-groups-list">
                        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    </VBox>
                    <HBox alignment="CENTER" styleClass="load-more-bar">
                        <Button fx:id="loadMoreButton" text="Показать еще" onAction="#loadMoreRates" styleClass="secondary-button">
                            <graphic><FontIcon iconLiteral="fas-chevron-down" iconSize="12" styleClass="app-icon"/></graphic>
                        </Button>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
