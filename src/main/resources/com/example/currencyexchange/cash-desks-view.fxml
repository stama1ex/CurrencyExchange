<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.controlsfx.control.SearchableComboBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.CashDeskController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Кассы" styleClass="page-title"/>
            <Label text="Управление филиалами и лимитами каждой обменной кассы" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox styleClass="section-card" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="Добавить" onAction="#addCashDesk" styleClass="primary-button">
                <graphic><FontIcon iconLiteral="fas-plus" iconSize="12" styleClass="app-icon"/></graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane prefWidth="250">
                <TextField fx:id="searchField" promptText="Поиск по названию, адресу или телефону" prefWidth="250" styleClass="search-field modern-search-field"/>
                <Button fx:id="clearSearchButton" onAction="#clearSearch" visible="false" managed="false" focusTraversable="false" StackPane.alignment="CENTER_RIGHT" styleClass="clear-button">
                    <graphic><FontIcon iconLiteral="fas-times" iconSize="12" styleClass="app-icon"/></graphic>
                </Button>
            </StackPane>
            <SearchableComboBox fx:id="filterStatusBox" prefWidth="145" promptText="Все"/>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="content-scroll">
            <content>
                <VBox fx:id="cashDeskCardsContainer" spacing="16" styleClass="cards-list">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
