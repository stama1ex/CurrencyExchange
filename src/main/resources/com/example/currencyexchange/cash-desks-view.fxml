<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.CashDeskController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Кассы" styleClass="page-title"/>
            <Label text="Управление филиалами и лимитами каждой обменной кассы" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="🏦 Сеть отделений" styleClass="mini-stat-title"/>
            <Label text="Поддерживайте корректные лимиты и статусы касс" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="🛡 Контроль лимитов" styleClass="mini-stat-title"/>
            <Label text="Минимальные и максимальные остатки видны прямо в таблице" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="⚙ Статусы работы" styleClass="mini-stat-title"/>
            <Label text="Фильтруйте работающие и закрытые кассы" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox styleClass="section-card" spacing="0" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="＋ Добавить" onAction="#addCashDesk" styleClass="primary-button"/>
            <Button text="✎ Изменить" onAction="#updateCashDesk" styleClass="secondary-button"/>
            <Button text="🗑 Удалить" onAction="#deleteCashDesk" styleClass="danger-button"/>
            <Button text="↻ Обновить" onAction="#refreshTable" styleClass="secondary-button"/>
            <Button text="⟲ Сбросить" onAction="#clearFilters" styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Поиск по названию или адресу" prefWidth="250" styleClass="search-field modern-search-field"/>
            <ComboBox fx:id="filterStatusBox" prefWidth="145" promptText="Статус"/>
            <Button text="Поиск" onAction="#searchAndFilter" styleClass="primary-button"/>
        </HBox>
        <TableView fx:id="cashDeskTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70" visible="false"/>
                <TableColumn fx:id="nameColumn" text="Название" prefWidth="220"/>
                <TableColumn fx:id="addressColumn" text="Адрес" prefWidth="280"/>
                <TableColumn fx:id="minLimitColumn" text="Мин. лимит" prefWidth="140"/>
                <TableColumn fx:id="maxLimitColumn" text="Макс. лимит" prefWidth="140"/>
                <TableColumn fx:id="statusColumn" text="Статус" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
