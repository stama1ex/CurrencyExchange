<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.IncassationController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Инкассации" styleClass="page-title"/>
            <Label text="Планируйте пополнения и изъятия средств по каждой кассе" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="🚚 Движение наличности" styleClass="mini-stat-title"/>
            <Label text="Отображаются пополнения и инкассации по всем валютам" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="🏷 Статусы выполнения" styleClass="mini-stat-title"/>
            <Label text="Фильтрация по статусу помогает контролировать процесс" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="📦 Операции по кассам" styleClass="mini-stat-title"/>
            <Label text="В таблице видно кассу, дату, валюту и тип операции" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox styleClass="section-card" spacing="0" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="＋ Добавить" onAction="#addIncassation" styleClass="primary-button"/>
            <Button text="✎ Изменить" onAction="#updateIncassation" styleClass="secondary-button"/>
            <Button text="Удалить" onAction="#deleteIncassation" styleClass="danger-button"/>
            <Button text="↻ Обновить" onAction="#refreshTable" styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Статус" styleClass="filter-label"/>
            <ComboBox fx:id="filterStatusBox" prefWidth="180"/>
        </HBox>
        <TableView fx:id="incassationTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70" visible="false"/>
                <TableColumn fx:id="cashDeskIdColumn" text="Касса" prefWidth="230"/>
                <TableColumn fx:id="dateColumn" text="Дата" prefWidth="140"/>
                <TableColumn fx:id="currencyCodeColumn" text="Валюта" prefWidth="190"/>
                <TableColumn fx:id="amountColumn" text="Сумма" prefWidth="150"/>
                <TableColumn fx:id="typeColumn" text="Тип" prefWidth="160"/>
                <TableColumn fx:id="statusColumn" text="Статус" prefWidth="160"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
