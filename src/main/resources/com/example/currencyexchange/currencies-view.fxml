<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.CurrencyController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Валюты" styleClass="page-title"/>
            <Label text="Каталог валют в карточном формате, как в современном веб-интерфейсе" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="mini-stat-card" HBox.hgrow="ALWAYS">
            <Label text="💱 Всего валют" styleClass="mini-stat-title"/>
            <Label fx:id="currenciesTotalLabel" text="0" styleClass="mini-stat-value"/>
        </VBox>
        <VBox styleClass="mini-stat-card" HBox.hgrow="ALWAYS">
            <Label text="✅ Выбрана" styleClass="mini-stat-title"/>
            <Label fx:id="selectedCurrencyLabel" text="—" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-stat-card" HBox.hgrow="ALWAYS">
            <Label text="🔎 Контекст поиска" styleClass="mini-stat-title"/>
            <Label fx:id="searchMetaLabel" text="Все валюты в системе" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox styleClass="section-card" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="＋ Добавить" onAction="#addCurrency" styleClass="primary-button"/>
            <Button text="✎ Изменить" onAction="#updateCurrency" styleClass="secondary-button"/>
            <Button text="🗑 Удалить" onAction="#deleteCurrency" styleClass="danger-button"/>
            <Button text="↻ Обновить" onAction="#refreshTable" styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane prefWidth="320">
                <TextField fx:id="searchField" promptText="Поиск по коду или названию валюты" onAction="#searchCurrencies" prefWidth="320" styleClass="search-field modern-search-field"/>
                <Button fx:id="clearSearchButton" text="×" onAction="#clearSearch" visible="false" managed="false" focusTraversable="false" StackPane.alignment="CENTER_RIGHT" styleClass="clear-button"/>
            </StackPane>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="content-scroll">
            <content>
                <TilePane fx:id="currencyCardsContainer" prefColumns="4" hgap="16" vgap="16" styleClass="cards-grid">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                </TilePane>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
