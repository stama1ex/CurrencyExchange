<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.currencyexchange.controller.ExchangeOperationController">
    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <VBox spacing="5">
            <Label text="Операции обмена" styleClass="page-title"/>
            <Label text="История сделок с мгновенной фильтрацией по дате" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="💸 Реальные обмены" styleClass="mini-stat-title"/>
            <Label text="Экран содержит ключевые суммы, курс и полученную валюту" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="📆 Фильтр по дате" styleClass="mini-stat-title"/>
            <Label text="Можно быстро отследить операции за конкретный день" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
        <VBox styleClass="mini-info-card" HBox.hgrow="ALWAYS">
            <Label text="🧾 Журнал операций" styleClass="mini-stat-title"/>
            <Label text="Все записи отсортированы по дате, самые свежие сверху" styleClass="mini-stat-description" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox styleClass="section-card" spacing="0" VBox.vgrow="ALWAYS">
        <HBox styleClass="toolbar modern-toolbar" spacing="10" alignment="CENTER_LEFT">
            <Button text="＋ Добавить" onAction="#addOperation" styleClass="primary-button"/>
            <Button text="✎ Изменить" onAction="#updateOperation" styleClass="secondary-button"/>
            <Button text="🗑 Удалить" onAction="#deleteOperation" styleClass="danger-button"/>
            <Button text="↻ Обновить" onAction="#refreshTable" styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="4">
                <Label text="Дата" styleClass="filter-label"/>
                <DatePicker fx:id="filterDatePicker" prefWidth="180" styleClass="flat-date-picker"/>
            </VBox>
        </HBox>
        <TableView fx:id="operationTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60" visible="false"/>
                <TableColumn fx:id="cashDeskIdColumn" text="Касса" prefWidth="200"/>
                <TableColumn fx:id="currencyFromColumn" text="Из валюты" prefWidth="120"/>
                <TableColumn fx:id="currencyToColumn" text="В валюту" prefWidth="120"/>
                <TableColumn fx:id="dateColumn" text="Дата" prefWidth="130"/>
                <TableColumn fx:id="amountFromColumn" text="Сумма из" prefWidth="130"/>
                <TableColumn fx:id="rateColumn" text="Курс" prefWidth="100"/>
                <TableColumn fx:id="amountToColumn" text="Сумма в" prefWidth="130"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
